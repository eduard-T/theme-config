{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@assets/*": [
        "./core/assets/*"
      ],
      "@components/*": [
        "./core/components/*"
      ],
      "@hooks/*": [
        "./core/hooks/*"
      ],
      "@providers/*": [
        "./core/providers/*"
      ],
      "@screens/*": [
        "./screens/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
